rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Role Helpers (ÖNEMLİ: Admin İzni Genişletildi)
    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'necmiharun3@gmail.com' || 
              request.auth.token.email == 'corbacicengizustabuca@gmail.com' ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }
    function isVip() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVip == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['user', 'vip', 'admin'] &&
             (!('phone' in data) || data.phone is string) &&
             (!('fullName' in data) || data.fullName is string) &&
             (!('isVip' in data) || data.isVip is bool);
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid &&
                    incoming().createdAt == request.time;
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && 
                        incoming().role == existing().role && 
                        incoming().isVip == existing().isVip) ||
                       isAdmin();
    }

    // Predictions Collection
    match /predictions/{predictionId} {
      allow list: if (resource.data.status == 'published' || resource.data.status == 'settled' || isAdmin()) && 
                    (resource.data.visibility in ['public', 'sample'] || isVip() || isAdmin());
      allow get: if (resource.data.status == 'published' || resource.data.status == 'settled' || isAdmin()) && 
                   (resource.data.visibility in ['public', 'sample'] || isVip() || isAdmin());
      
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() ||
                       (incoming().diff(existing()).affectedKeys().hasOnly(['views']) && 
                        incoming().views == existing().views + 1);
      allow delete: if isAdmin();
    }

    match /slider/{sliderId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banks/{bankId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
